# =============================================================================
# Trade the Past — Environment Variables
# =============================================================================
# Copy to .env and fill in values:  cp .env.example .env

# ---------------------------------------------------------------------------
# REQUIRED — app will refuse to start without this
# ---------------------------------------------------------------------------

# AES-256 encryption key for cookie encryption (64 hex chars = 32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# eToro SSO (OAuth 2.0 + PKCE) — optional, enables "Continue with eToro" login
# ---------------------------------------------------------------------------
ETORO_SSO_CLIENT_ID=
ETORO_SSO_CLIENT_SECRET=
ETORO_SSO_REDIRECT_URI=https://trade-the-past.etoro.app/auth/callback

# Client-side variants (exposed to browser for PKCE initiation)
NEXT_PUBLIC_ETORO_SSO_CLIENT_ID=
NEXT_PUBLIC_ETORO_SSO_REDIRECT_URI=https://trade-the-past.etoro.app/auth/callback

# Override if eToro gives a different authorization URL for your app registration
# NEXT_PUBLIC_ETORO_SSO_AUTHORIZE_URL=

# ---------------------------------------------------------------------------
# News & AI — optional, app works without them (RSS primary, local matching)
# ---------------------------------------------------------------------------

# NewsAPI — free tier: 100 requests/day (localhost only in free plan)
# Sign up: https://newsapi.org/register
NEWSAPI_KEY=

# OpenAI — GPT-4o-mini for AI-powered historical matching
# Without this, the app falls back to the built-in historical database
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
